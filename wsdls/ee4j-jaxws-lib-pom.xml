<?xml version="1.0" encoding="UTF-8"?>
<!--
  Populates wsdls/lib/provided with EE4J JAX-WS tooling for Ant wsimport (build.xml). No Metro webservices-*.
  JARs resolve from Maven Central (Eclipse EE4J). Keep ee4j.jaxws.version aligned with ../pom.xml.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <groupId>au.gov.nehta</groupId>
    <artifactId>mhr-wsdls-jaxws-lib</artifactId>
    <version>1.0.0</version>
    <packaging>pom</packaging>
    <name>MHR WSDLs - EE4J JAX-WS lib sync (internal)</name>

    <properties>
        <!-- Keep in sync with ee4j.jaxws.version in ../pom.xml -->
        <ee4j.jaxws.version>2.3.7</ee4j.jaxws.version>
        <ant.contrib.version>1.0b3</ant.contrib.version>
        <encoding>UTF-8</encoding>
        <project.build.sourceEncoding>${encoding}</project.build.sourceEncoding>
        <plugin.dependency.version>3.10.0</plugin.dependency.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>com.sun.xml.ws</groupId>
            <artifactId>jaxws-tools</artifactId>
            <version>${ee4j.jaxws.version}</version>
        </dependency>
        <dependency>
            <groupId>com.sun.xml.ws</groupId>
            <artifactId>jaxws-rt</artifactId>
            <version>${ee4j.jaxws.version}</version>
        </dependency>
        <dependency>
            <groupId>ant-contrib</groupId>
            <artifactId>ant-contrib</artifactId>
            <version>${ant.contrib.version}</version>
            <exclusions>
                <exclusion>
                    <groupId>ant</groupId>
                    <artifactId>ant</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>${plugin.dependency.version}</version>
                <executions>
                    <execution>
                        <id>copy-ee4j-jaxws-for-ant</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-dependencies</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${project.basedir}/lib/provided</outputDirectory>
                            <overWriteReleases>true</overWriteReleases>
                            <stripVersion>false</stripVersion>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
