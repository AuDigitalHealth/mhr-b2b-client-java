<?xml version="1.0" encoding="UTF-8"?>
<!--
  Optional Maven user settings fragment. Copy sections into ~/.m2/settings.xml
  or pass with: mvn -s path/to/settings.xml
  Do not commit a settings.xml that contains server passwords or tokens.
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">
    <servers>
        <server>
            <id>nexus-snapshots</id>
            <!-- username / password from Sonatype — set locally, not in Git -->
        </server>
        <server>
            <id>nexus-releases</id>
        </server>
    </servers>
</settings>
