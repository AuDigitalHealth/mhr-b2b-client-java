# Example placeholders — align with your ADHA registration pack when wiring tests.

# MHR_KEYSTORE_TYPE=PKCS12
# MHR_KEYSTORE_PATH=./certs/<your-ra-folder>/fac_sign.p12
# MHR_KEYSTORE_PASSWORD=
# MHR_KEY_PASSWORD=

# MHR_TRUSTSTORE_TYPE=JKS
# MHR_TRUSTSTORE_PATH=./src/test/resources/truststore.jks
# MHR_TRUSTSTORE_PASSWORD=

# MHR_PCEHR_ENDPOINT_BASE=https://b2b.example.health.gov.au
